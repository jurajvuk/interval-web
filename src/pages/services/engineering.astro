---
/*
  src/pages/services/engineering.astro
  Individual service page for Project Management & Engineering.
*/

import ServiceLayout from '../../layouts/ServiceLayout.astro';
---

<ServiceLayout
  title="Project Management & Engineering"
  subtitle="Design, consulting, and supervision in electrical engineering and naval architecture — from classification documentation to complete workshop drawings."
  pageTitle="Project Management & Engineering | Interval"
>

  <!-- INTRO -->
  <div class="mb-16">
    <h2 class="text-2xl md:text-3xl font-extrabold mb-6">
      Marine & Industrial Drawing Design
    </h2>
    <p class="text-brand-gray leading-relaxed mb-6">
      The engineering department offers services in project management,
      design, consulting, and supervision of works in the fields of
      electrical engineering and naval architecture.
    </p>
    <p class="text-brand-gray leading-relaxed">
      Interval is recognized and approved by CRS and Bureau Veritas for
      design and development of technical documentation for marine vessels.
      This includes both classification documentation and workshop
      documentation.
    </p>
  </div>

  <!-- CLASSIFICATION DOCUMENTATION -->
  <div class="mb-16">
    <div class="font-mono text-[0.68rem] text-brand-orange tracking-[4px] uppercase mb-6 flex items-center gap-3">
      <span class="w-5 h-0.5 bg-brand-orange"></span>
      Classification Documentation
    </div>

    <p class="text-brand-gray leading-relaxed mb-8">
      We produce complete classification documentation packages approved
      by CRS and Bureau Veritas for marine vessel electrical systems.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-brand-orange/5">

      <div class="bg-brand-black p-6">
        <span class="font-mono text-brand-orange text-[0.65rem] tracking-[2px]">///</span>
        <p class="text-sm text-brand-gray-light mt-2">Electric load balance</p>
      </div>
      <div class="bg-brand-black p-6">
        <span class="font-mono text-brand-orange text-[0.65rem] tracking-[2px]">///</span>
        <p class="text-sm text-brand-gray-light mt-2">Power distribution — one line electric diagram</p>
      </div>
      <div class="bg-brand-black p-6">
        <span class="font-mono text-brand-orange text-[0.65rem] tracking-[2px]">///</span>
        <p class="text-sm text-brand-gray-light mt-2">Short circuit calculation</p>
      </div>
      <div class="bg-brand-black p-6">
        <span class="font-mono text-brand-orange text-[0.65rem] tracking-[2px]">///</span>
        <p class="text-sm text-brand-gray-light mt-2">Fire detection system diagram & sensor arrangement</p>
      </div>
      <div class="bg-brand-black p-6">
        <span class="font-mono text-brand-orange text-[0.65rem] tracking-[2px]">///</span>
        <p class="text-sm text-brand-gray-light mt-2">General arrangement of main electrical equipment</p>
      </div>
      <div class="bg-brand-black p-6">
        <span class="font-mono text-brand-orange text-[0.65rem] tracking-[2px]">///</span>
        <p class="text-sm text-brand-gray-light mt-2">Safety stops block diagram</p>
      </div>
      <div class="bg-brand-black p-6">
        <span class="font-mono text-brand-orange text-[0.65rem] tracking-[2px]">///</span>
        <p class="text-sm text-brand-gray-light mt-2">Internal communication — PA / GA block diagram</p>
      </div>
      <div class="bg-brand-black p-6">
        <span class="font-mono text-brand-orange text-[0.65rem] tracking-[2px]">///</span>
        <p class="text-sm text-brand-gray-light mt-2">Intercommunication system — telephone diagrams</p>
      </div>
      <div class="bg-brand-black p-6">
        <span class="font-mono text-brand-orange text-[0.65rem] tracking-[2px]">///</span>
        <p class="text-sm text-brand-gray-light mt-2">Steering gear control diagram</p>
      </div>
      <div class="bg-brand-black p-6">
        <span class="font-mono text-brand-orange text-[0.65rem] tracking-[2px]">///</span>
        <p class="text-sm text-brand-gray-light mt-2">Tank gauging — level switches & transmitters</p>
      </div>
      <div class="bg-brand-black p-6">
        <span class="font-mono text-brand-orange text-[0.65rem] tracking-[2px]">///</span>
        <p class="text-sm text-brand-gray-light mt-2">External & internal lighting arrangement</p>
      </div>
      <div class="bg-brand-black p-6">
        <span class="font-mono text-brand-orange text-[0.65rem] tracking-[2px]">///</span>
        <p class="text-sm text-brand-gray-light mt-2">Ventilation dampers block diagram</p>
      </div>

    </div>
  </div>

  <!-- WORKSHOP DOCUMENTATION -->
  <div class="mb-16">
    <div class="font-mono text-[0.68rem] text-brand-orange tracking-[4px] uppercase mb-6 flex items-center gap-3">
      <span class="w-5 h-0.5 bg-brand-orange"></span>
      Workshop Documentation
    </div>

    <p class="text-brand-gray leading-relaxed mb-8">
      Three pole diagrams of electrical control cabinets and counters
      developed in our manufacturing facility, covering all systems.
    </p>

    <div class="space-y-4">

      <div class="flex gap-4 items-start p-6 bg-brand-dark/50 border border-brand-orange/5 hover:border-brand-orange/15 transition-colors">
        <span class="font-mono text-brand-orange text-sm mt-0.5 shrink-0">01</span>
        <div>
          <h4 class="font-bold mb-1">Automation System Cabinets</h4>
          <p class="text-sm text-brand-gray leading-relaxed">
            Cabinets and counters with I/O field devices, PLC controllers,
            and HMI devices.
          </p>
        </div>
      </div>

      <div class="flex gap-4 items-start p-6 bg-brand-dark/50 border border-brand-orange/5 hover:border-brand-orange/15 transition-colors">
        <span class="font-mono text-brand-orange text-sm mt-0.5 shrink-0">02</span>
        <div>
          <h4 class="font-bold mb-1">Electrical Distribution & PMS</h4>
          <p class="text-sm text-brand-gray leading-relaxed">
            Electrical distribution cabinets, power management systems,
            and main switchboard systems.
          </p>
        </div>
      </div>

      <div class="flex gap-4 items-start p-6 bg-brand-dark/50 border border-brand-orange/5 hover:border-brand-orange/15 transition-colors">
        <span class="font-mono text-brand-orange text-sm mt-0.5 shrink-0">03</span>
        <div>
          <h4 class="font-bold mb-1">Generator & Motor Systems</h4>
          <p class="text-sm text-brand-gray leading-relaxed">
            Diesel generator protection and monitoring systems, Motor
            Control Centres (MCC), and associated drive systems.
          </p>
        </div>
      </div>

      <div class="flex gap-4 items-start p-6 bg-brand-dark/50 border border-brand-orange/5 hover:border-brand-orange/15 transition-colors">
        <span class="font-mono text-brand-orange text-sm mt-0.5 shrink-0">04</span>
        <div>
          <h4 class="font-bold mb-1">Vessel Systems</h4>
          <p class="text-sm text-brand-gray leading-relaxed">
            Hydraulic winches, bow thrusters, capstans, HVAC, potable
            water systems, and tank level measuring systems.
          </p>
        </div>
      </div>

    </div>
  </div>

  <!-- APPROVALS HIGHLIGHT -->
  <div class="mb-16 p-8 md:p-12 border border-brand-orange/10 relative overflow-hidden">

    <div class="absolute -right-8 -top-8 w-[160px] h-[160px] [clip-path:polygon(50%_0%,0%_100%,100%_100%)] bg-brand-orange opacity-[0.04]"></div>

    <div class="font-mono text-[0.68rem] text-brand-orange tracking-[4px] uppercase mb-4 flex items-center gap-3">
      <span class="w-5 h-0.5 bg-brand-orange"></span>
      Recognized & Approved
    </div>

    <h2 class="text-2xl font-extrabold mb-6">
      Classification Society Approvals
    </h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      <div class="border-l-2 border-brand-orange/20 pl-4">
        <h4 class="text-sm font-bold mb-1">CRS — Croatian Register of Shipping</h4>
        <p class="text-xs text-brand-gray leading-relaxed">
          Recognized and approved for design and development of technical
          documentation for marine vessels.
        </p>
      </div>
      <div class="border-l-2 border-brand-orange/20 pl-4">
        <h4 class="text-sm font-bold mb-1">Bureau Veritas</h4>
        <p class="text-xs text-brand-gray leading-relaxed">
          Approved for design and development of marine vessel electrical
          documentation under BV classification.
        </p>
      </div>
    </div>
  </div>

  <!-- SERVICES SCOPE -->
  <div>
    <div class="font-mono text-[0.68rem] text-brand-orange tracking-[4px] uppercase mb-6 flex items-center gap-3">
      <span class="w-5 h-0.5 bg-brand-orange"></span>
      Scope of Services
    </div>
    <div class="flex flex-wrap gap-4">
      <div class="font-mono text-sm text-brand-gray-dark tracking-wider uppercase px-6 py-4 border border-brand-orange/5 hover:border-brand-orange/15 hover:text-brand-gray-light transition-all">Project Management</div>
      <div class="font-mono text-sm text-brand-gray-dark tracking-wider uppercase px-6 py-4 border border-brand-orange/5 hover:border-brand-orange/15 hover:text-brand-gray-light transition-all">Electrical Design</div>
      <div class="font-mono text-sm text-brand-gray-dark tracking-wider uppercase px-6 py-4 border border-brand-orange/5 hover:border-brand-orange/15 hover:text-brand-gray-light transition-all">Naval Architecture</div>
      <div class="font-mono text-sm text-brand-gray-dark tracking-wider uppercase px-6 py-4 border border-brand-orange/5 hover:border-brand-orange/15 hover:text-brand-gray-light transition-all">Consulting</div>
      <div class="font-mono text-sm text-brand-gray-dark tracking-wider uppercase px-6 py-4 border border-brand-orange/5 hover:border-brand-orange/15 hover:text-brand-gray-light transition-all">Supervision</div>
      <div class="font-mono text-sm text-brand-gray-dark tracking-wider uppercase px-6 py-4 border border-brand-orange/5 hover:border-brand-orange/15 hover:text-brand-gray-light transition-all">Technical Documentation</div>
    </div>
  </div>

  <!-- RELATED SERVICES -->
  <Fragment slot="related">
    <a href="/services/automation" class="group block bg-brand-black-soft p-8 border border-brand-orange/5 hover:border-brand-orange/15 transition-all">
      <div class="font-mono text-[0.65rem] text-brand-gray-dark tracking-[2px] mb-4">01</div>
      <h3 class="text-lg font-bold mb-2 group-hover:text-brand-orange transition-colors">Automation</h3>
      <p class="text-sm text-brand-gray">Custom automation and visualization systems for marine and industrial applications.</p>
    </a>
    <a href="/services/cabinets" class="group block bg-brand-black-soft p-8 border border-brand-orange/5 hover:border-brand-orange/15 transition-all">
      <div class="font-mono text-[0.65rem] text-brand-gray-dark tracking-[2px] mb-4">03</div>
      <h3 class="text-lg font-bold mb-2 group-hover:text-brand-orange transition-colors">Electrical Cabinets</h3>
      <p class="text-sm text-brand-gray">SIVACON S8 switchboard design and manufacturing.</p>
    </a>
    <a href="/services/commissioning" class="group block bg-brand-black-soft p-8 border border-brand-orange/5 hover:border-brand-orange/15 transition-all">
      <div class="font-mono text-[0.65rem] text-brand-gray-dark tracking-[2px] mb-4">06</div>
      <h3 class="text-lg font-bold mb-2 group-hover:text-brand-orange transition-colors">Installation & Commissioning</h3>
      <p class="text-sm text-brand-gray">On-site installation, testing, and commissioning services.</p>
    </a>
  </Fragment>

</ServiceLayout>
