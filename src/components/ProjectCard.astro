---
import { Image } from 'astro:assets';
interface Props {
    title: string;
    category: string;
    image: ImageMetadata;
}

const { title, category, image } = Astro.props;
---
<a href={title} class="group block relative overflow-hidden transition-colors hover:text-brand-orange duration-400 hover:bg-brand-dark">
    <Image src={image} alt={title} class="w-full h-full object-cover opacity-50 transition-all duration-500 group-hover:scale-105 group-hover:opacity-80" />
    <div class="absolute inset-0 bg-linear-to-t from-black/70 via-transparent to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
    <!-- Arrow (appears on hover) -->
    <div class="absolute -bottom-5 left-0 right-0 p-6 font-mono text-[0.72rem] text-brand-orange flex flex-col gap-1.5 opacity-0 -translate-y-2.5 transition-all duration-300 group-hover:opacity-100 group-hover:translate-y-0">
        <p>{category}</p>
        <p class="text-sm font-bold mb-2 text-white">{title}</p>
    </div>
</a>
