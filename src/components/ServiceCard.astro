---
interface Props {
  title: string;
  description: string;
  href: string;
}

const { title, description, href } = Astro.props;

---
<a href={href} class="block p-6 bg-brand-black rounded-lg transition-colors">
    <h3 class="text-xl font-bold mb-2">{title}</h3>
    <p class="text-brand-gray">{description}</p>
</a>
